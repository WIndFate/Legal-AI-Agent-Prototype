OPENAI_API_KEY=sk-your-api-key-here

# Database (Supabase PostgreSQL in production, local postgres in dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/contract_checker

# Redis (Upstash in production, local redis in dev)
REDIS_URL=redis://redis:6379

# KOMOJU Payment
KOMOJU_SECRET_KEY=sk_...
KOMOJU_PUBLISHABLE_KEY=pk_...
KOMOJU_WEBHOOK_SECRET=whsec_...

# Resend Email
RESEND_API_KEY=re_...

# Sentry Error Tracking
SENTRY_DSN=

# PostHog Analytics
POSTHOG_API_KEY=

# App Config
FRONTEND_URL=http://localhost:5173
