OPENAI_API_KEY=sk-your-api-key-here
OCR_MODEL=google-vision-document-text
ANALYSIS_MODEL=gpt-4o
PARSE_MODEL=gpt-4o-mini
SUGGESTION_MODEL=gpt-4o-mini
TRANSLATION_MODEL=gpt-4o-mini
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_VISION_PROJECT_ID=
DAILY_COST_BUDGET_JPY=500
GOOGLE_VISION_COST_PER_PAGE_JPY=0.225

# Runtime environment: development | production
APP_ENV=development

# Database (Supabase PostgreSQL in production, local postgres in dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/contract_checker

# Redis (Upstash in production, local redis in dev)
REDIS_URL=redis://redis:6379

# KOMOJU Payment
KOMOJU_SECRET_KEY=sk_...
KOMOJU_PUBLISHABLE_KEY=pk_...
KOMOJU_WEBHOOK_SECRET=whsec_...

# Resend Email
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=noreply@mail.contractguard.jp
EMAIL_FROM_NAME=ContractGuard
EMAIL_REPLY_TO=support@contractguard.jp

# Sentry Error Tracking
SENTRY_DSN=

# PostHog Analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# App Config
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_PAGES=30
MAX_CONTRACT_TOKENS=60000
OCR_WASTE_DAILY_LIMIT=10
PRICING_POLICY_FILE=backend/data/pricing_policy.json
COST_SAMPLE_SEED_FILE=backend/data/cost_samples_seed.json
COST_SAMPLE_MINIMUM=10

# Frontend analytics (optional)
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
